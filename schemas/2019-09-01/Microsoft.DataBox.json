{
  "id": "https://schema.management.azure.com/schemas/2019-09-01/Microsoft.DataBox.json#",
  "title": "Microsoft.DataBox",
  "description": "Microsoft DataBox Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "resourceDefinitions": {
    "jobs": {
      "description": "Microsoft.DataBox/jobs",
      "properties": {
        "apiVersion": {
          "enum": [
            "2019-09-01"
          ],
          "type": "string"
        },
        "location": {
          "description": "The location of the resource. This will be one of the supported and registered Azure Regions (e.g. West US, East US, Southeast Asia, etc.). The region of a resource cannot be changed once it is created, but if an identical region is specified on update the request will succeed.",
          "type": "string"
        },
        "name": {
          "description": "The resource name",
          "oneOf": [
            {
              "maxLength": 24,
              "minLength": 3,
              "pattern": "^[-\\w\\.]+$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "Properties of a job.",
          "oneOf": [
            {
              "$ref": "#/definitions/JobProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "sku": {
          "description": "The sku type.",
          "oneOf": [
            {
              "$ref": "#/definitions/Sku"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "tags": {
          "description": "The list of key value pairs that describe the resource. These tags can be used in viewing and grouping this resource (across resource groups).",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.DataBox/jobs"
          ],
          "type": "string"
        }
      },
      "required": [
        "location",
        "name",
        "properties",
        "sku",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "ContactDetails": {
      "properties": {
        "contactName": {
          "description": "Contact name of the person.",
          "type": "string"
        },
        "emailList": {
          "description": "List of Email-ids to be notified about job progress.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "mobile": {
          "description": "Mobile number of the contact person.",
          "type": "string"
        },
        "notificationPreference": {
          "description": "Notification preference for a job stage.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/NotificationPreference"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "phone": {
          "description": "Phone number of the contact person.",
          "type": "string"
        },
        "phoneExtension": {
          "description": "Phone extension number of the contact person.",
          "type": "string"
        }
      },
      "required": [
        "contactName",
        "emailList",
        "phone"
      ],
      "type": "object"
    },
    "DataBoxDiskJobDetails": {
      "properties": {
        "jobDetailsType": {
          "description": "Indicates the type of job details.",
          "oneOf": [
            {
              "enum": [
                "DataBoxDisk"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "passkey": {
          "description": "User entered passkey for DataBox Disk job.",
          "type": "string"
        },
        "preferredDisks": {
          "description": "User preference on what size disks are needed for the job. The map is from the disk size in TB to the count. Eg. {2,5} means 5 disks of 2 TB size. Key is string but will be checked against an int.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "integer"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "jobDetailsType"
      ],
      "type": "object"
    },
    "DataBoxDiskJobDetailsPreferredDisks": {
      "additionalProperties": {
        "type": "integer"
      },
      "properties": {},
      "type": "object"
    },
    "DataBoxHeavyJobDetails": {
      "properties": {
        "devicePassword": {
          "description": "Set Device password for unlocking Databox Heavy",
          "type": "string"
        },
        "jobDetailsType": {
          "description": "Indicates the type of job details.",
          "oneOf": [
            {
              "enum": [
                "DataBoxHeavy"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "jobDetailsType"
      ],
      "type": "object"
    },
    "DataBoxJobDetails": {
      "properties": {
        "devicePassword": {
          "description": "Set Device password for unlocking Databox",
          "type": "string"
        },
        "jobDetailsType": {
          "description": "Indicates the type of job details.",
          "oneOf": [
            {
              "enum": [
                "DataBox"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "jobDetailsType"
      ],
      "type": "object"
    },
    "DestinationAccountDetails": {
      "allOf": [
        {
          "additionalProperties": false,
          "properties": {
            "accountId": {
              "description": "Arm Id of the destination where the data has to be moved.",
              "type": "string"
            },
            "dataDestinationType": {
              "enum": [
                "ManagedDisk",
                "StorageAccount"
              ],
              "type": "string"
            },
            "sharePassword": {
              "description": "Share password to be shared by all shares in SA.",
              "type": "string"
            }
          },
          "required": [
            "dataDestinationType"
          ],
          "type": "object"
        },
        {
          "oneOf": [
            {
              "allOf": [
                {
                  "$ref": "#/definitions/DestinationManagedDiskDetails"
                },
                {
                  "properties": {
                    "dataDestinationType": {
                      "const": "ManagedDisk"
                    }
                  },
                  "required": [
                    "dataDestinationType"
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/definitions/DestinationStorageAccountDetails"
                },
                {
                  "properties": {
                    "dataDestinationType": {
                      "const": "StorageAccount"
                    }
                  },
                  "required": [
                    "dataDestinationType"
                  ],
                  "type": "object"
                }
              ]
            }
          ]
        }
      ]
    },
    "DestinationManagedDiskDetails": {
      "properties": {
        "dataDestinationType": {
          "description": "Data Destination Type.",
          "oneOf": [
            {
              "enum": [
                "ManagedDisk"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "resourceGroupId": {
          "description": "Destination Resource Group Id where the Compute disks should be created.",
          "type": "string"
        },
        "stagingStorageAccountId": {
          "description": "Arm Id of the storage account that can be used to copy the vhd for staging.",
          "type": "string"
        }
      },
      "required": [
        "dataDestinationType",
        "resourceGroupId",
        "stagingStorageAccountId"
      ],
      "type": "object"
    },
    "DestinationStorageAccountDetails": {
      "properties": {
        "dataDestinationType": {
          "description": "Data Destination Type.",
          "oneOf": [
            {
              "enum": [
                "StorageAccount"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "storageAccountId": {
          "description": "Destination Storage Account Arm Id.",
          "type": "string"
        }
      },
      "required": [
        "dataDestinationType",
        "storageAccountId"
      ],
      "type": "object"
    },
    "JobDeliveryInfo": {
      "properties": {
        "scheduledDateTime": {
          "description": "Scheduled date time.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "JobDetails": {
      "allOf": [
        {
          "additionalProperties": false,
          "properties": {
            "contactDetails": {
              "description": "Contact details for notification and shipping.",
              "oneOf": [
                {
                  "$ref": "#/definitions/ContactDetails"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "destinationAccountDetails": {
              "description": "Destination account details.",
              "oneOf": [
                {
                  "items": {
                    "$ref": "#/definitions/DestinationAccountDetails"
                  },
                  "type": "array"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "expectedDataSizeInTeraBytes": {
              "description": "The expected size of the data, which needs to be transferred in this job, in terabytes.",
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "jobDetailsType": {
              "enum": [
                "DataBox",
                "DataBoxDisk",
                "DataBoxHeavy"
              ],
              "type": "string"
            },
            "preferences": {
              "description": "Preferences for the order.",
              "oneOf": [
                {
                  "$ref": "#/definitions/Preferences"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "shippingAddress": {
              "description": "Shipping address of the customer.",
              "oneOf": [
                {
                  "$ref": "#/definitions/ShippingAddress"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            }
          },
          "required": [
            "contactDetails",
            "destinationAccountDetails",
            "shippingAddress",
            "jobDetailsType"
          ],
          "type": "object"
        },
        {
          "oneOf": [
            {
              "allOf": [
                {
                  "$ref": "#/definitions/DataBoxJobDetails"
                },
                {
                  "properties": {
                    "jobDetailsType": {
                      "const": "DataBox"
                    }
                  },
                  "required": [
                    "jobDetailsType"
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/definitions/DataBoxDiskJobDetails"
                },
                {
                  "properties": {
                    "jobDetailsType": {
                      "const": "DataBoxDisk"
                    }
                  },
                  "required": [
                    "jobDetailsType"
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/definitions/DataBoxHeavyJobDetails"
                },
                {
                  "properties": {
                    "jobDetailsType": {
                      "const": "DataBoxHeavy"
                    }
                  },
                  "required": [
                    "jobDetailsType"
                  ],
                  "type": "object"
                }
              ]
            }
          ]
        }
      ]
    },
    "JobProperties": {
      "properties": {
        "deliveryInfo": {
          "description": "Delivery Info of Job.",
          "oneOf": [
            {
              "$ref": "#/definitions/JobDeliveryInfo"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "deliveryType": {
          "description": "Delivery type of Job.",
          "oneOf": [
            {
              "enum": [
                "NonScheduled",
                "Scheduled"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "details": {
          "description": "Details of a job run. This field will only be sent for expand details filter.",
          "oneOf": [
            {
              "$ref": "#/definitions/JobDetails"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "NotificationPreference": {
      "properties": {
        "sendNotification": {
          "description": "Notification is required or not.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "stageName": {
          "description": "Name of the stage.",
          "oneOf": [
            {
              "enum": [
                "DevicePrepared",
                "Dispatched",
                "Delivered",
                "PickedUp",
                "AtAzureDC",
                "DataCopy"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "sendNotification",
        "stageName"
      ],
      "type": "object"
    },
    "Preferences": {
      "properties": {
        "preferredDataCenterRegion": {
          "description": "Preferred Data Center Region.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "transportPreferences": {
          "description": "Preferences related to the shipment logistics of the sku.",
          "oneOf": [
            {
              "$ref": "#/definitions/TransportPreferences"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "ResourceTags": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "type": "object"
    },
    "ShippingAddress": {
      "properties": {
        "addressType": {
          "description": "Type of address.",
          "oneOf": [
            {
              "enum": [
                "None",
                "Residential",
                "Commercial"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "city": {
          "description": "Name of the City.",
          "type": "string"
        },
        "companyName": {
          "description": "Name of the company.",
          "type": "string"
        },
        "country": {
          "description": "Name of the Country.",
          "type": "string"
        },
        "postalCode": {
          "description": "Postal code.",
          "type": "string"
        },
        "stateOrProvince": {
          "description": "Name of the State or Province.",
          "type": "string"
        },
        "streetAddress1": {
          "description": "Street Address line 1.",
          "type": "string"
        },
        "streetAddress2": {
          "description": "Street Address line 2.",
          "type": "string"
        },
        "streetAddress3": {
          "description": "Street Address line 3.",
          "type": "string"
        },
        "zipExtendedCode": {
          "description": "Extended Zip Code.",
          "type": "string"
        }
      },
      "required": [
        "country",
        "postalCode",
        "streetAddress1"
      ],
      "type": "object"
    },
    "Sku": {
      "properties": {
        "displayName": {
          "description": "The display name of the sku.",
          "type": "string"
        },
        "family": {
          "description": "The sku family.",
          "type": "string"
        },
        "name": {
          "description": "The sku name.",
          "oneOf": [
            {
              "enum": [
                "DataBox",
                "DataBoxDisk",
                "DataBoxHeavy"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "TransportPreferences": {
      "properties": {
        "preferredShipmentType": {
          "description": "Indicates Shipment Logistics type that the customer preferred.",
          "oneOf": [
            {
              "enum": [
                "CustomerManaged",
                "MicrosoftManaged"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "preferredShipmentType"
      ],
      "type": "object"
    }
  }
}