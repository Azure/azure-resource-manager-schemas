        "objectId": {
          "description": "The AAD object identifier for the entity to create a policy for.",
          "oneOf": [
            {
              "maxLength": 36,
              "minLength": 36,
              "pattern": "^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$",
              "type": "string"
            },
