            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "severity": {
          "description": "The severity of the incident",
          "oneOf": [
            {
              "enum": [
                "High",
                "Medium",
                "Low",
                "Informational"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "status": {
          "description": "The status of the incident",
