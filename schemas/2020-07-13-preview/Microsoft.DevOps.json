{
  "id": "https://schema.management.azure.com/schemas/2020-07-13-preview/Microsoft.DevOps.json#",
  "title": "Microsoft.DevOps",
  "description": "Microsoft DevOps Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "resourceDefinitions": {
    "pipelines": {
      "description": "Microsoft.DevOps/pipelines",
      "properties": {
        "apiVersion": {
          "enum": [
            "2020-07-13-preview"
          ],
          "type": "string"
        },
        "location": {
          "description": "Resource Location",
          "type": "string"
        },
        "name": {
          "description": "The resource name",
          "type": "string"
        },
        "properties": {
          "description": "Custom properties of the Pipeline.",
          "oneOf": [
            {
              "$ref": "#/definitions/PipelineProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "tags": {
          "description": "Resource Tags",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.DevOps/pipelines"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "Authorization": {
      "properties": {
        "authorizationType": {
          "description": "Type of authorization.",
          "oneOf": [
            {
              "enum": [
                "personalAccessToken"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "parameters": {
          "description": "Authorization parameters corresponding to the authorization type.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "authorizationType"
      ],
      "type": "object"
    },
    "AuthorizationParameters": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "type": "object"
    },
    "AzurePipelineProperties": {
      "properties": {
        "organization": {
          "description": "Reference to the Azure DevOps Organization containing the Pipeline. Required for 'azurePipeline' pipeline type.",
          "oneOf": [
            {
              "$ref": "#/definitions/OrganizationReference"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "pipelineType": {
          "description": "Specifies which CI/CD provider to use. Valid options are 'azurePipeline', 'githubWorkflow'.",
          "oneOf": [
            {
              "enum": [
                "azurePipeline"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "project": {
          "description": "Reference to the Azure DevOps Project containing the Pipeline. Required for 'azurePipeline' pipeline type.",
          "oneOf": [
            {
              "$ref": "#/definitions/ProjectReference"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "organization",
        "pipelineType",
        "project"
      ],
      "type": "object"
    },
    "BootstrapConfiguration": {
      "properties": {
        "sourceRepository": {
          "description": "Repository containing the source code for the pipeline. Currently only 'azurePipeline' pipeline type supports this.",
          "oneOf": [
            {
              "$ref": "#/definitions/CodeRepository"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "template": {
          "description": "Template used to bootstrap the pipeline.",
          "oneOf": [
            {
              "$ref": "#/definitions/PipelineTemplate"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "template"
      ],
      "type": "object"
    },
    "CodeRepository": {
      "properties": {
        "authorization": {
          "description": "Authorization info to access the code repository.",
          "oneOf": [
            {
              "$ref": "#/definitions/Authorization"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "defaultBranch": {
          "description": "Default branch used to configure Continuous Integration (CI) in the pipeline.",
          "type": "string"
        },
        "id": {
          "description": "Unique immutable identifier of the code repository.",
          "type": "string"
        },
        "properties": {
          "description": "Repository-specific properties.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "repositoryType": {
          "description": "Type of code repository.",
          "oneOf": [
            {
              "enum": [
                "gitHub",
                "vstsGit"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "defaultBranch",
        "id",
        "repositoryType"
      ],
      "type": "object"
    },
    "CodeRepositoryProperties": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "type": "object"
    },
    "GithubWorkflowProperties": {
      "properties": {
        "pipelineType": {
          "description": "Specifies which CI/CD provider to use. Valid options are 'azurePipeline', 'githubWorkflow'.",
          "oneOf": [
            {
              "enum": [
                "githubWorkflow"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "repository": {
          "description": "Contains the specifications of the repository to be created for generating the workflow. Required for 'githubWorkflow' pipeline type.",
          "oneOf": [
            {
              "$ref": "#/definitions/CodeRepository"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "pipelineType",
        "repository"
      ],
      "type": "object"
    },
    "OrganizationReference": {
      "properties": {
        "name": {
          "description": "Name of the Azure DevOps Organization.",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "PipelineProperties": {
      "allOf": [
        {
          "additionalProperties": false,
          "properties": {
            "bootstrapConfiguration": {
              "description": "Configuration used to bootstrap the Pipeline.",
              "oneOf": [
                {
                  "$ref": "#/definitions/BootstrapConfiguration"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "pipelineType": {
              "enum": [
                "azurePipeline",
                "githubWorkflow"
              ],
              "type": "string"
            }
          },
          "required": [
            "bootstrapConfiguration",
            "pipelineType"
          ],
          "type": "object"
        },
        {
          "oneOf": [
            {
              "allOf": [
                {
                  "$ref": "#/definitions/AzurePipelineProperties"
                },
                {
                  "properties": {
                    "pipelineType": {
                      "const": "azurePipeline"
                    }
                  },
                  "required": [
                    "pipelineType"
                  ],
                  "type": "object"
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/definitions/GithubWorkflowProperties"
                },
                {
                  "properties": {
                    "pipelineType": {
                      "const": "githubWorkflow"
                    }
                  },
                  "required": [
                    "pipelineType"
                  ],
                  "type": "object"
                }
              ]
            }
          ]
        }
      ]
    },
    "PipelineTemplate": {
      "properties": {
        "id": {
          "description": "Unique identifier of the pipeline template.",
          "type": "string"
        },
        "parameters": {
          "description": "Dictionary of input parameters used in the pipeline template.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "id"
      ],
      "type": "object"
    },
    "PipelineTemplateParameters": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "type": "object"
    },
    "ProjectReference": {
      "properties": {
        "name": {
          "description": "Name of the Azure DevOps Project.",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ResourceTags": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "type": "object"
    }
  }
}