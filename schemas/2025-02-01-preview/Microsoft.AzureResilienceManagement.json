      ],
      "properties": {
        "description": {
          "description": "A description of the recovery orchestration group action, containing the instructions to be performed during this action.",
          "maxLength": 100,
          "type": "string"
        },
        "name": {
          "description": "The name of the recovery orchestration group action.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9-]{3,24}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "timeoutInMinutes": {
          "description": "The maximum amount of time, in minutes, allowed for the action to complete before it times out.",
