{
  "id": "https://schema.management.azure.com/schemas/2025-10-03/Microsoft.Monitor.Accounts.json#",
  "title": "Microsoft.Monitor",
  "description": "Microsoft Monitor Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "resourceDefinitions": {
    "accounts": {
      "description": "Microsoft.Monitor/accounts",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-10-03"
          ],
          "type": "string"
        },
        "identity": {
          "description": "The managed service identities assigned to this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/ManagedServiceIdentity"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "location": {
          "description": "The geo-location where the resource lives",
          "type": "string"
        },
        "name": {
          "description": "The name of the Azure Monitor Workspace. The name is case insensitive",
          "oneOf": [
            {
              "pattern": "^(?!-)[a-zA-Z0-9-]+[^-]$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "Resource properties",
          "oneOf": [
            {
              "$ref": "#/definitions/AzureMonitorWorkspace"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "resources": {
          "items": {
            "oneOf": [
              {
                "$ref": "#/definitions/accounts_issues_childResource"
              },
              {
                "$ref": "#/definitions/accounts_metricsContainers_childResource"
              }
            ]
          },
          "type": "array"
        },
        "tags": {
          "description": "Resource tags.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.Monitor/accounts"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    },
    "accounts_issues": {
      "description": "Microsoft.Monitor/accounts/issues",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-10-03"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the IssueResource",
          "oneOf": [
            {
              "pattern": "^(?!-)[a-zA-Z0-9-]+[^-]$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/IssueProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.Monitor/accounts/issues"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    },
    "accounts_metricsContainers": {
      "description": "Microsoft.Monitor/accounts/metricsContainers",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-10-03"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the MetricsContainer",
          "oneOf": [
            {
              "pattern": "^default$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/MetricsContainer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.Monitor/accounts/metricsContainers"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "AzureMonitorWorkspace": {
      "description": "Properties of an Azure Monitor Workspace",
      "properties": {
        "metrics": {
          "description": "Properties related to the metrics container in the Azure Monitor Workspace",
          "oneOf": [
            {
              "$ref": "#/definitions/AzureMonitorWorkspaceMetrics"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "publicNetworkAccess": {
          "description": "Gets or sets allow or disallow public network access to Azure Monitor Workspace",
          "oneOf": [
            {
              "enum": [
                "Enabled",
                "Disabled"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "AzureMonitorWorkspaceMetrics": {
      "description": "Properties related to the metrics container in the Azure Monitor Workspace",
      "properties": {
        "enableAccessUsingResourcePermissions": {
          "description": "Flag that indicates whether to enable access using resource permissions.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "Background": {
      "description": "The issue background information",
      "properties": {
        "details": {
          "description": "The background details",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/BackgroundDetails"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "text": {
          "description": "The background text",
          "type": "string"
        },
        "type": {
          "description": "The background type",
          "type": "string"
        }
      },
      "type": "object"
    },
    "BackgroundDetails": {
      "description": "A background details element",
      "properties": {
        "name": {
          "description": "The background details name",
          "type": "string"
        },
        "value": {
          "description": "The background details value",
          "type": "string"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "type": "object"
    },
    "IssueNotificationType": {
      "description": "Base properties for an issue notification type",
      "oneOf": [
        {
          "description": "Notification type for issue creation events",
          "properties": {
            "updateType": {
              "enum": [
                "IssueCreation"
              ],
              "type": "string"
            }
          },
          "required": [
            "updateType"
          ],
          "type": "object"
        },
        {
          "description": "Notification type for on-change events",
          "properties": {
            "updateType": {
              "enum": [
                "OnChange"
              ],
              "type": "string"
            }
          },
          "required": [
            "updateType"
          ],
          "type": "object"
        },
        {
          "description": "Notification type for time-based updates",
          "properties": {
            "updateInterval": {
              "description": "The interval between time-based updates",
              "type": "string"
            },
            "updateType": {
              "enum": [
                "TimeBased"
              ],
              "type": "string"
            }
          },
          "required": [
            "updateInterval",
            "updateType"
          ],
          "type": "object"
        }
      ],
      "properties": {},
      "type": "object"
    },
    "IssueProperties": {
      "description": "The issue properties",
      "properties": {
        "background": {
          "description": "The issue background information",
          "oneOf": [
            {
              "$ref": "#/definitions/Background"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "impactTime": {
          "description": "The issue impact time (in UTC)",
          "format": "date-time",
          "type": "string"
        },
        "notifications": {
          "description": "The issue notification settings",
          "oneOf": [
            {
              "$ref": "#/definitions/Notifications"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "severity": {
          "description": "The issue severity",
          "type": "string"
        },
        "status": {
          "description": "The issue status",
          "oneOf": [
            {
              "enum": [
                "New",
                "InProgress",
                "Mitigated",
                "Closed",
                "Canceled"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "title": {
          "description": "The issue title",
          "type": "string"
        }
      },
      "required": [
        "title",
        "status",
        "severity",
        "impactTime"
      ],
      "type": "object"
    },
    "ManagedServiceIdentity": {
      "description": "Managed service identity (system assigned and/or user assigned identities)",
      "properties": {
        "type": {
          "description": "Type of managed service identity (where both SystemAssigned and UserAssigned types are allowed).",
          "oneOf": [
            {
              "enum": [
                "None",
                "SystemAssigned",
                "UserAssigned",
                "SystemAssigned,UserAssigned"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "userAssignedIdentities": {
          "description": "The set of user assigned identities associated with the resource. The userAssignedIdentities dictionary keys will be ARM resource ids in the form: '/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedIdentity/userAssignedIdentities/{identityName}. The dictionary values can be empty objects ({}) in requests.",
          "oneOf": [
            {
              "additionalProperties": {
                "$ref": "#/definitions/UserAssignedIdentity"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "MetricsContainer": {
      "description": "Properties of a metrics container.",
      "properties": {
        "version": {
          "description": "The version of Metrics Query Service that this AMW will use for all metric queries.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Notifications": {
      "description": "Issue notification settings",
      "properties": {
        "actionGroupIds": {
          "description": "The action group IDs to notify",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "excludeDefaultActionGroups": {
          "description": "Whether to exclude default action groups from notifications",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "updateTypes": {
          "description": "The types of updates that trigger notifications",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/IssueNotificationType"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "UserAssignedIdentity": {
      "description": "User assigned identity properties",
      "properties": {},
      "type": "object"
    },
    "accounts_issues_childResource": {
      "description": "Microsoft.Monitor/accounts/issues",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-10-03"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the IssueResource",
          "oneOf": [
            {
              "pattern": "^(?!-)[a-zA-Z0-9-]+[^-]$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/IssueProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "issues"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    },
    "accounts_metricsContainers_childResource": {
      "description": "Microsoft.Monitor/accounts/metricsContainers",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-10-03"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the MetricsContainer",
          "oneOf": [
            {
              "pattern": "^default$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/MetricsContainer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "metricsContainers"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  }
}