  "definitions": {
    "HorizonDbClusterParameterGroupConnectionProperties": {
      "description": "Connection information for HorizonDB parameter group.",
      "properties": {
        "applyImmediately": {
          "description": "Indicates whether the parameters should be applied immediately.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "id": {
          "description": "The resource ID of the connected parameter group.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "HorizonDbClusterProperties": {
      "description": "Properties of a HorizonDB cluster.",
      "properties": {
        "administratorLogin": {
          "description": "The administrator login name.",
          "maxLength": 63,
          "minLength": 1,
          "type": "string"
        },
        "administratorLoginPassword": {
          "description": "The administrator login password.",
          "type": "string"
        },
        "createMode": {
          "description": "The mode to create a new HorizonDB cluster.",
          "oneOf": [
            {
              "enum": [
                "Create",
                "Update",
                "PointInTimeRestore"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "network": {
          "description": "The network related info.",
          "oneOf": [
            {
              "$ref": "#/definitions/Network"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "parameterGroup": {
          "description": "Defines connection to a parameter group.",
          "oneOf": [
            {
              "$ref": "#/definitions/HorizonDbClusterParameterGroupConnectionProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "pointInTimeUTC": {
          "description": "Restore point creation time specifying the time to restore from.",
          "format": "date-time",
          "type": "string"
        },
        "poolName": {
          "description": "The pool name for restore or replica operations.",
          "type": "string"
        },
        "processorType": {
          "description": "The processor type for the HorizonDB cluster.",
          "type": "string"
        },
        "replicaCount": {
          "description": "Number of replicas.",
          "oneOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "sourceClusterResourceId": {
          "description": "The source cluster resource ID for restore or replica creation.",
          "type": "string"
        },
        "vCores": {
          "description": "Number of vCores.",
          "oneOf": [
            {
              "maximum": 96,
              "minimum": 1,
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "version": {
          "description": "The version of the HorizonDB cluster.",
          "type": "string"
        },
        "zonePlacementPolicy": {
          "description": "Defines how replicas are placed across availability zones.",
          "oneOf": [
            {
              "enum": [
                "Strict",
                "BestEffort"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "administratorLogin"
      ],
      "type": "object"
    },
    "HorizonDbFirewallRuleProperties": {
      "description": "Properties of a HorizonDB firewall rule.",
      "properties": {
        "description": {
          "description": "The description of the HorizonDB firewall rule.",
          "type": "string"
        },
        "endIpAddress": {
          "description": "The end IP address of the firewall rule (IPv4).",
          "type": "string"
        },
        "startIpAddress": {
          "description": "The start IP address of the firewall rule (IPv4).",
          "type": "string"
        }
      },
      "required": [
        "startIpAddress",
        "endIpAddress"
      ],
      "type": "object"
    },
    "HorizonDbParameterGroupProperties": {
      "description": "Properties of a HorizonDB parameter group.",
      "properties": {
        "applyImmediately": {
          "description": "Indicates whether the parameters should be applied immediately.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "description": {
          "description": "Description of the parameter group.",
          "type": "string"
        },
        "parameters": {
          "description": "Parameters in the parameter group.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/ParameterProperties"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "pgVersion": {
          "description": "PostgreSQL version for the parameter group.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "HorizonDbReplicaProperties": {
      "description": "Properties of a HorizonDB replica.",
      "properties": {
        "availabilityZone": {
          "description": "The availability zone of the replica.",
          "type": "string"
        },
        "role": {
          "description": "Role of the replica.",
          "oneOf": [
            {
              "enum": [
                "Read",
                "ReadWrite"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "Network": {
      "description": "Network properties.",
      "properties": {},
      "type": "object"
    },
    "ParameterProperties": {
      "description": "Properties of a HorizonDB parameters.",
      "properties": {
        "name": {
          "description": "The name of the parameter.",
          "type": "string"
        },
        "value": {
          "description": "The value of the configuration.",
          "type": "string"
        }
      },
      "type": "object"
    }
  }
}