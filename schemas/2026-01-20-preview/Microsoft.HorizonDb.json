{
  "id": "https://schema.management.azure.com/schemas/2026-01-20-preview/Microsoft.HorizonDb.json#",
  "title": "Microsoft.HorizonDb",
  "description": "Microsoft HorizonDb Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
