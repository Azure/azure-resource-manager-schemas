{
  "id": "https://schema.management.azure.com/schemas/2026-03-01-preview/Microsoft.ProgramEnrollment.json#",
  "title": "Microsoft.ProgramEnrollment",
  "description": "Microsoft ProgramEnrollment Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "resourceDefinitions": {
    "eduEnrollments": {
      "description": "Microsoft.ProgramEnrollment/eduEnrollments",
      "properties": {
        "apiVersion": {
          "enum": [
            "2026-03-01-preview"
          ],
          "type": "string"
        },
        "location": {
          "description": "The geo-location where the resource lives",
          "type": "string"
        },
        "name": {
          "description": "The name of the edu enrollment",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9-]{3,24}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/EduEnrollmentProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "tags": {
          "description": "Resource tags.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.ProgramEnrollment/eduEnrollments"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "DomainGroup": {
      "description": "A group of edu domains scoped to an Entra tenant.",
      "properties": {
        "domainNames": {
          "description": "The edu domain names in this group.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "tenantId": {
          "description": "The Entra tenant ID that owns these domains. Defaults to the caller's tenant if omitted.",
          "oneOf": [
            {
              "pattern": "^[0-9a-fA-F]{8}(-[0-9a-fA-F]{4}){3}-[0-9a-fA-F]{12}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "domainNames"
      ],
      "type": "object"
    },
    "EduEnrollmentProperties": {
      "description": "Details of the Program EduEnrollment.",
      "properties": {
        "domains": {
          "description": "The domain groups associated with this enrollment.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/DomainGroup"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "domains"
      ],
      "type": "object"
    }
  }
}