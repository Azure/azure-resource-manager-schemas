  "definitions": {
    "AssessmentProperties": {
      "description": "The properties of an Assessment resource",
      "properties": {
        "assessmentType": {
          "description": "The name of the assessment template whose rules will be evaluated (e.g. 'Edu'). Immutable after creation.",
          "oneOf": [
            {
              "enum": [
                "Edu",
                "BusinessVerification",
                "PayeeEnrollment",
                "PayeeProfile"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "initialValues": {
          "description": "Optional initial values applied to the rules created with this assessment. Write-only — these values are routed to the per-kind rules and are not returned on read.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/InitialRuleValueBase"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "assessmentType"
      ],
      "type": "object"
    },
    "DomainEntry": {
      "description": "A domain entry within an education qualification rule. `domainNames` and `tenantId` are supplied on creation; `state` and `error` are returned by the service.",
      "properties": {
        "domainNames": {
          "description": "Domain names associated with a tenant.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "tenantId": {
          "description": "The Microsoft Entra tenant ID owning these domains. Defaults to the calling user's tenant when omitted.",
          "oneOf": [
            {
              "pattern": "^[0-9a-fA-F]{8}(-[0-9a-fA-F]{4}){3}-[0-9a-fA-F]{12}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "domainNames"
      ],
      "type": "object"
    },
    "ExternalId": {
      "description": "External-registry identifier (e.g. DUNS) used to disambiguate ambiguous verification matches.",
      "properties": {
        "type": {
          "description": "Identifier type. Currently `DUNS` is supported.",
          "maxLength": 100,
          "type": "string"
        },
        "value": {
          "description": "Identifier value (e.g. the DUNS number string).",
          "maxLength": 100,
          "type": "string"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "type": "object"
    },
    "InitialRuleValueBase": {
      "description": "Base type for write-only initial values supplied when creating an assessment. Polymorphic by `kind`; per-kind initial values forward into the corresponding rule.",
      "oneOf": [
        {
          "description": "Initial values for an education qualification rule. Per-domain entries (`domainNames` + `tenantId`) are used to populate the rule when the assessment is created.",
          "properties": {
            "domains": {
              "description": "Per-domain entries to use when populating the education qualification rule. Only `domainNames` and `tenantId` are read from this payload; `state` and `error` on each entry are populated by the service.",
              "oneOf": [
                {
                  "items": {
                    "$ref": "#/definitions/DomainEntry"
                  },
                  "type": "array"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "kind": {
              "enum": [
                "eduQualification"
              ],
              "type": "string"
            }
          },
          "required": [
            "domains",
            "kind"
          ],
          "type": "object"
        }
      ],
      "properties": {},
      "type": "object"
    },
    "RuleProperties": {
      "description": "Base properties of a Rule resource. Polymorphic by `kind` — kind-specific writable fields live on derived models.",
      "oneOf": [
        {
          "description": "Properties of a business verification rule. Verifies the billing account's\nbusiness identity.\n\nSold-to fields (`soldTo`, `registrationNumber`, `taxIds`) reflect the billing\naccount's information on file and cannot be supplied by end users.",
          "properties": {
            "externalId": {
              "description": "Optional external-registry identifier (e.g. DUNS) used to disambiguate verification matches. Settable on PATCH while `evaluationState` is `pending` or `actionRequired`.",
              "oneOf": [
                {
                  "$ref": "#/definitions/ExternalId"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "kind": {
              "enum": [
                "businessVerification"
              ],
              "type": "string"
            },
            "supplementalDocuments": {
              "description": "References to supplemental documents (businessVerification rules only; only settable while evaluationState is `pending` or `actionRequired`).",
              "oneOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Properties of an eduQualification rule. Verifies education-domain ownership for a billing account.",
          "properties": {
            "domains": {
              "description": "Per-tenant domain entries to verify.",
              "oneOf": [
                {
                  "items": {
                    "$ref": "#/definitions/DomainEntry"
                  },
                  "type": "array"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "kind": {
              "enum": [
                "eduQualification"
              ],
              "type": "string"
            },
            "supplementalDocuments": {
              "description": "References to supplemental documents. Settable only when evaluationState is `actionRequired`.",
              "oneOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ],
      "properties": {},
      "type": "object"
    },
    "assessments_rules_childResource": {
      "description": "Microsoft.BillingTrust/assessments/rules",
      "properties": {
        "apiVersion": {
          "enum": [
            "2026-03-17-preview"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the rule. Rules are created by the service when the parent assessment is created — the available rule names are determined by the assessment template. Names start with an alphanumeric character and may contain letters, digits, underscores, and hyphens.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{2,63}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/RuleProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "rules"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  }
