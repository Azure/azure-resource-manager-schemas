  "definitions": {
    "AssetPropertiesOfDrill": {
      "description": "Drill asset properties.",
      "properties": {
        "region": {
          "description": "Region where Drill's internal resources will be created.",
          "type": "string"
        },
        "resourceGroup": {
          "description": "Resource group where Drill's internal resources will be created. If not specified, defaults to 'AzureResilienceManagementDrills'. This value is immutable after drill creation.",
          "oneOf": [
            {
              "maxLength": 90,
              "minLength": 1,
              "pattern": "^[-\\w\\._\\(\\)]+$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "subscription": {
          "description": "Subscription where Drill's internal resources will be created.",
          "type": "string"
        }
      },
      "required": [
        "subscription",
        "region"
      ],
      "type": "object"
    },
    "AssociatedIdentity": {
      "description": "Definition of associated identity linked with the various resources.",
      "properties": {
        "type": {
          "description": "Identity type linked with the resource",
          "oneOf": [
            {
              "enum": [
                "None",
                "SystemAssigned",
                "UserAssigned",
                "SystemAssigned,UserAssigned"
              ],
              "type": "string"
            },
