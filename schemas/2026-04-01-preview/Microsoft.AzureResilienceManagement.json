              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "userAssignedIdentity": {
          "description": "User assigned identity id linked with the resource",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ChaosResourcePropertiesOfDrill": {
      "description": "Chaos Resource properties.",
      "properties": {
        "chaosResourceIdentityForFaults": {
          "description": "Identity to be used by the Chaos Resource for invoking faults on resources.",
          "oneOf": [
            {
              "$ref": "#/definitions/AssociatedIdentity"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "identity": {
          "description": "Identity to use for Chaos Resource operations.",
          "oneOf": [
            {
              "$ref": "#/definitions/AssociatedIdentity"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "identity",
        "chaosResourceIdentityForFaults"
      ],
      "type": "object"
    },
