          ]
        },
        "monitoringProperties": {
          "description": "Monitoring properties of the Drill.",
          "oneOf": [
            {
              "$ref": "#/definitions/MonitoringPropertiesOfDrill"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "rbacSetupMode": {
          "description": "RBAC setup mode.",
          "oneOf": [
            {
              "enum": [
                "AutomatedCustomRole",
                "AutomatedBuiltinRoles",
                "Manual"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "recoveryPlanProperties": {
          "description": "ROPlan properties.",
          "oneOf": [
            {
              "$ref": "#/definitions/RecoveryPlanPropertiesOfDrill"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "EnrollmentProperties": {
      "description": "Definition of enrollment properties.",
      "properties": {
        "serviceGroupId": {
          "description": "ARM resource identifier of the service group associated with this usage plan.",
          "type": "string"
        }
      },
      "required": [
        "serviceGroupId"
      ],
      "type": "object"
    },
    "GoalAssignmentProperties": {
      "description": "Definition of goal assignment property.",
      "properties": {
        "goalAssignmentType": {
          "description": "The type of goal assignment.",
          "oneOf": [
            {
              "enum": [
                "Resiliency"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "goalTemplateId": {
          "description": "Arm id of the goal template.",
          "type": "string"
        },
        "serviceLevelResources": {
          "description": "List of service level resources.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/ServiceLevelResource"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "goalTemplateId",
        "goalAssignmentType"
      ],
      "type": "object"
    },
    "GoalTemplateProperties": {
      "description": "Definition of goal template property.",
      "properties": {
        "goalType": {
          "description": "Type of Goal Template created by customer",
          "oneOf": [
            {
              "enum": [
                "Resiliency"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "regionalRecoveryPointObjective": {
          "description": "Regional recovery point objective specified by customer. eg, PT15M for 15 minutes",
          "type": "string"
        },
        "regionalRecoveryTimeObjective": {
          "description": "Regional recovery time objective specified by customer. eg, PT15M for 15 minutes",
          "type": "string"
        },
        "requireDisasterRecovery": {
          "description": "Option specified by customer under disaster recovery section of goal template",
          "oneOf": [
            {
              "enum": [
                "NotRequired",
                "Required"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "requireHighAvailability": {
          "description": "Option specified by customer under high availability section of goal template",
          "oneOf": [
            {
              "enum": [
                "NotRequired",
                "Required"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "goalType"
      ],
      "type": "object"
    },
    "ManagedServiceIdentity": {
      "description": "Managed service identity (system assigned and/or user assigned identities)",
      "properties": {
        "type": {
          "description": "Type of managed service identity (where both SystemAssigned and UserAssigned types are allowed).",
          "oneOf": [
            {
              "enum": [
                "None",
                "SystemAssigned",
                "UserAssigned",
                "SystemAssigned,UserAssigned"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "userAssignedIdentities": {
          "description": "The set of user assigned identities associated with the resource. The userAssignedIdentities dictionary keys will be ARM resource ids in the form: '/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedIdentity/userAssignedIdentities/{identityName}. The dictionary values can be empty objects ({}) in requests.",
          "oneOf": [
            {
              "additionalProperties": {
                "$ref": "#/definitions/UserAssignedIdentity"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "MonitoringPropertiesOfDrill": {
      "description": "Drill monitoring properties.",
      "properties": {
        "identity": {
          "description": "Identity to use for Drill monitoring operations.",
          "oneOf": [
            {
              "$ref": "#/definitions/AssociatedIdentity"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "RecoveryGroup": {
      "description": "Represents a recovery orchestration group resource in the Azure Resilience Management provider namespace.",
      "properties": {
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/RecoveryGroupProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "RecoveryGroupBaseAction": {
      "description": "Defines an action for the recovery orchestration group.",
      "oneOf": [
        {
          "description": "Defines a custom runbook action for the recovery orchestration group.",
          "properties": {
            "actionResourceId": {
              "description": "The ARM Resource ID of the resource that includes the actionable script, such as a Runbook in an Automation Account.",
              "type": "string"
            },
            "associatedIdentity": {
              "description": "The identity associated with actionResourceId for RBAC.",
              "oneOf": [
                {
                  "$ref": "#/definitions/AssociatedIdentity"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "parameters": {
              "description": "Key-value parameters for the operation.",
              "oneOf": [
                {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "properties": {},
                  "type": "object"
                },
                {
                  "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
                }
              ]
            },
            "type": {
              "enum": [
                "CustomRunbook"
              ],
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Defines a manual action for the recovery orchestration group.",
          "properties": {
            "type": {
              "enum": [
                "ManualAction"
              ],
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "description": {
          "description": "A description of the recovery orchestration group action, containing the instructions to be performed during this action.",
          "maxLength": 100,
          "type": "string"
        },
        "name": {
          "description": "The name of the recovery orchestration group action.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9-]{3,24}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "timeoutInMinutes": {
          "description": "The maximum amount of time, in minutes, allowed for the action to complete before it times out.",
          "oneOf": [
            {
              "maximum": 10000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "name",
        "timeoutInMinutes"
      ],
      "type": "object"
    },
    "RecoveryGroupProperties": {
      "description": "Properties of the recovery orchestration group.",
      "properties": {
        "description": {
          "description": "A description of the recovery orchestration group.",
          "maxLength": 50,
          "minLength": 5,
          "type": "string"
        },
        "groupUniqueId": {
          "description": "A unique id for the recovery orchestration group, which is a GUID.",
          "oneOf": [
            {
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "orderId": {
          "description": "The order ID of the recovery orchestration group.",
          "oneOf": [
            {
              "maximum": 15,
              "minimum": 0,
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "postActions": {
          "description": "Post-actions for the recovery orchestration group.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/RecoveryGroupBaseAction"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "preActions": {
          "description": "Pre-actions for the recovery orchestration group.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/RecoveryGroupBaseAction"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "groupUniqueId",
        "orderId",
        "description"
      ],
      "type": "object"
    },
    "RecoveryGroupsSetting": {
      "description": "Settings for the recovery orchestration groups.",
      "properties": {
        "additionalGroups": {
          "description": "Additional recovery orchestration group settings.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/RecoveryGroup"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
