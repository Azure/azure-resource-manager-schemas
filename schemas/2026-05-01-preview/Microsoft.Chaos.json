        "parameters",
        "selectorId",
        "type"
      ],
      "type": "object"
    },
    "CustomerDataStorageProperties": {
      "properties": {
        "blobContainerName": {
          "description": "Name of the Azure Blob Storage container to use or create.",
          "oneOf": [
            {
              "maxLength": 63,
              "minLength": 3,
              "pattern": "^[a-z0-9]([a-z0-9]|(-(?!-))){1,61}[a-z0-9]$",
